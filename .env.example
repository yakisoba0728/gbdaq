# 실제 Claude 애널리스트를 켜려면 키를 넣으세요(없으면 휴리스틱 폴백). https://console.anthropic.com
ANTHROPIC_API_KEY=

# 데모 접속 비밀번호. 사이트 게이트 + /api/analyze 세션 보호에 쓰입니다.
# 비우면 아무도 데모에 입장할 수 없습니다(로컬은 .env.local, 배포는 Vercel 환경변수에 설정).
DEMO_PASSWORD=

# AI 분석 킬스위치: 1로 설정 시 /api/analyze가 모델 호출 없이 폴백(비용 즉시 차단).
ANALYZE_DISABLED=
